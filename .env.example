# ===== API =====
API_PORT=3333
API_HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://finance:finance@localhost:5432/finance_dev

# Auth
JWT_ACCESS_SECRET=change-me-in-prod-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-in-prod-min-32-chars-different
JWT_REFRESH_EXPIRES=7d

# Argon2 (defaults OWASP — não mexa sem entender)
ARGON_MEMORY_COST=19456
ARGON_TIME_COST=2
ARGON_PARALLELISM=1

# CORS / cookies
ALLOWED_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=localhost

# Swagger
ENABLE_SWAGGER=true

# FX provider
FX_PROVIDER=frankfurter
FX_PROVIDER_BASE_URL=https://api.frankfurter.dev/v1
FX_FETCH_CRON=0 6 * * *

# ===== WEB =====
WEB_PORT=3000
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR
NEXT_PUBLIC_SUPPORTED_LOCALES=pt-BR,en-US,es-ES

# BFF → API (server-side only, NÃO expor)
API_INTERNAL_URL=http://localhost:3333/api/v1
COOKIE_REFRESH_NAME=fin_rt
COOKIE_REFRESH_SECRET=change-me-in-prod-min-32-chars
