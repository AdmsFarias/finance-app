# Dependências
node_modules/

# Yarn Berry — com nodeLinker: node-modules mantemos releases/patches/plugins versionados
# mas ignoramos cache/install-state/SDKs (regerados pelo install / yarn dlx @yarnpkg/sdks)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# Build
dist/
build/
.next/
.turbo/
*.tsbuildinfo

# Test
coverage/

# Env — nunca subir; usar os .example como template
.env
.env.*
!.env.example
!.env.local.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Chaves e certificados
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
id_rsa*

# Dumps / bancos locais
*.sql
*.sqlite
*.sqlite3
*.db
*.dump

# Backups locais
*.bak
*.backup
*.orig

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Temporários
tmp/
temp/


