# Copy to .env.local — Next carrega automaticamente.
# API_INTERNAL_URL é usado SOMENTE server-side pelo BFF proxy.
# Use 127.0.0.1 (not "localhost"): on Windows, Node resolves "localhost" as IPv6
# (::1) and the API bound to 0.0.0.0 only listens on IPv4 -> ECONNREFUSED.
API_INTERNAL_URL=http://127.0.0.1:3333/api/v1

# Exposto ao cliente
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR
NEXT_PUBLIC_SUPPORTED_LOCALES=pt-BR,en-US,es-ES
